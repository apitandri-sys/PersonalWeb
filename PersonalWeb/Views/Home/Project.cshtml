@{
    ViewData["Title"] = "Project";
}

<h2 class="mb-4">My Projects</h2>

<div class="row">

    <!-- Project 1 -->
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <img src="https://via.placeholder.com/400x200" class="card-img-top" alt="Todo App">
            <div class="card-body">
                <h5 class="card-title">Todo App MVC</h5>
                <p class="card-text">
                    Aplikasi manajemen tugas sederhana berbasis ASP.NET Core MVC.
                    User dapat menambah, mengedit, dan menghapus todo list.
                </p>
                <p><strong>Tech:</strong> C#, ASP.NET Core, SQL Server</p>
            </div>
        </div>
    </div>

    <!-- Project 2 -->
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <img src="https://via.placeholder.com/400x200" class="card-img-top" alt="Personal Web">
            <div class="card-body">
                <h5 class="card-title">Personal Portfolio Website</h5>
                <p class="card-text">
                    Website portfolio pribadi untuk menampilkan profil, skill, dan project.
                    Dibuat menggunakan ASP.NET Core dengan tampilan responsive.
                </p>
                <p><strong>Tech:</strong> HTML, CSS, Bootstrap</p>
            </div>
        </div>
    </div>

    <!-- Project 3 -->
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <img src="https://via.placeholder.com/400x200" class="card-img-top" alt="CRUD App">
            <div class="card-body">
                <h5 class="card-title">CRUD Data Karyawan</h5>
                <p class="card-text">
                    Aplikasi CRUD untuk mengelola data karyawan (Tambah, Edit, Hapus, List).
                    Menggunakan Entity Framework dan SQL Server.
                </p>
                <p><strong>Tech:</strong> C#, Entity Framework, SQL Server</p>
            </div>
        </div>
    </div>

</div>