@{
    ViewData["Title"] = "Skill";
}

<h2 class="mb-4">My Skills</h2>

<div class="container">

    <div class="mb-3">
        <label>C#</label>
        <div class="progress">
            <div class="progress-bar bg-success" style="width: 75%">
                75%
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label>ASP.NET Core</label>
        <div class="progress">
            <div class="progress-bar bg-info" style="width: 90%">
                90%
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label>HTML</label>
        <div class="progress">
            <div class="progress-bar bg-warning" style="width: 99%">
